{
    "name": "yebto/api-client",
    "description": "Base PHP client for YEB APIs. Works standalone or with Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": ["yeb", "api", "sdk", "client", "php"],
    "homepage": "https://yeb.to",
    "support": {
        "email": "support@yeb.to",
        "issues": "https://github.com/yebto/api-client/issues",
        "source": "https://github.com/yebto/api-client"
    },
    "authors": [
        {
            "name": "NETOX Ltd.",
            "email": "support@yeb.to",
            "homepage": "https://yeb.to",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel Facade & ServiceProvider integration (^10.0|^11.0|^12.0)"
    },
    "autoload": {
        "psr-4": {
            "Yebto\\ApiClient\\": "src/"
        }
    }
}
